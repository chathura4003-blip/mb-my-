{
  "$schema": "https://railway.app/template.schema.json",
  "services": {
    "supreme-mdbot-v3": {
      "name": "Supreme-MDBot-V3",
      "source": {
        "repo": "https://github.com/chathura4003-blip/mb-my-"
      },
      "config": {
        "rootDirectory": "./",
        "watchPatterns": ["./**"]
      },
      "variables": {
        "OWNER_NUMBER": {
          "description": "Your WhatsApp number (e.g., 94742514900)",
          "required": true
        },
        "PREFIX": {
          "description": "Command Prefix",
          "default": "."
        },
        "PORT": {
          "description": "Port for Dashboard",
          "default": "5000"
        }
      },
      "volumes": [
        {
          "mountPath": "/app/artifacts/whatsapp-bot/session"
        }
      ]
    }
  }
}
